{
  "rewrites": [
    {
      "source": "/trainer/:channel/:username",
      "destination": "/public/profile.html"
    },
    {
      "source": "/admin/:channel/:username",
      "destination": "/public/admin.html"
    },
    {
      "source": "/:path*",
      "destination": "/public/:path*"
    }
  ]
}
